# ============================================================
# UFM ADMISSION BOT — BIẾN MÔI TRƯỜNG (.env)
# Copy file này thành .env rồi điền giá trị thực
# ⚠️  KHÔNG BAO GIỜ commit file .env lên Git!
# ============================================================

# ─────────────────────────────────────────────────────────────
# 1. DATABASE — PostgreSQL + pgvector
# Image: pgvector/pgvector:pg16 (docker-compose.yml)
# ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost                 # "localhost" nếu chạy local, "postgres_vector" nếu Docker
POSTGRES_PORT=5432
POSTGRES_USER=ufm_admin
POSTGRES_PASSWORD=ufm_secure_password_2026
POSTGRES_DB=ufm_admission_db

# ─────────────────────────────────────────────────────────────
# 2. APP — FastAPI Server
# ─────────────────────────────────────────────────────────────
APP_PORT=8000

# ─────────────────────────────────────────────────────────────
# 3. ADMIN — Đăng nhập Admin Panel (/admin)
# ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=ufm_admin
ADMIN_PASSWORD=ufm_admin_2026
ADMIN_JWT_SECRET=thay-bang-chuoi-bi-mat-random-64-ky-tu

# ─────────────────────────────────────────────────────────────
# 4. LLM API KEYS — Các provider AI dùng trong pipeline
# ─────────────────────────────────────────────────────────────

# OpenRouter (BẮT BUỘC — dùng cho hầu hết các model)
# Đăng ký tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq Cloud (Tùy chọn — dùng cho embedding hoặc fallback)
# Đăng ký tại: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Gemini Direct (Tùy chọn — backup)
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (Tùy chọn — backup)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────────────────────
# 5. pgAdmin 4 (Tùy chọn — Giao diện quản trị DB)
# Chạy: docker compose --profile admin up
# Truy cập: http://localhost:5050
# ─────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@ufm.edu.vn
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
